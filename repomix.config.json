{
  "$schema": "https://repomix.com/repomix-config.schema.json",
  "output": {
    "filePath": "real-ecommerce-front.xml",
    "style": "markdown",
    "removeComments": false,
    "showLineNumbers": true,
    "topFilesLength": 5
  },
  "include": ["**/*"],
  "ignore": {
    "customPatterns": [
      ".next/**",
      "node_modules/**",
      ".pnpm-store/**",
      "out/**",
      "public/**",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.svg",
      "**/*.ico",
      "**/*.webp",
      "tailwind.config.{js,ts}",
      "postcss.config.{js,cjs}",
      "components/ui/**",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml"
    ],
    "useGitignore": true,
    "useDefaultPatterns": true
  }
}