30: export function selectCarrier(weight: number, value: number): "envia" | "welivery" | "correo" {
31:   // Envia: Light packages < 5kg, any value
32:   if (weight < 5) {
33:     return "envia"
34:   }
35: 
36:   // Welivery: Medium packages 5-20kg, value $50-$2000
37:   if (weight >= 5 && weight <= 20 && value >= 50 && value <= 2000) {
38:     return "welivery"
39:   }
40: 
41:   // Correo: Heavy packages > 20kg or high value > $2000
42:   if (weight > 20 || value > 2000) {
43:     return "correo"
44:   }
45: 
46:   // Default to welivery for edge cases
47:   return "welivery"
48: }
