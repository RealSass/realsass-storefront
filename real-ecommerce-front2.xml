50: export class ShippingService {
51:   private adapters: Map<string, ShippingAdapter> = new Map()
52: 
53:   registerAdapter(carrier: string, adapter: ShippingAdapter) {
54:     this.adapters.set(carrier, adapter)
55:   }
56: 
57:   async getQuotes(details: ShipmentDetails): Promise<CarrierQuote[]> {
58:     const quotes: CarrierQuote[] = []
59: 
60:     for (const [_, adapter] of this.adapters) {
61:       try {
62:         const quote = await adapter.calculateShipping(details)
63:         quotes.push(quote)
64:       } catch (error) {
65:         console.error(`[v0] Error getting quote from ${adapter.name}:`, error)
66:       }
67:     }
68: 
69:     return quotes.sort((a, b) => a.price - b.price)
70:   }
71: 
72:   async createShipment(details: ShipmentDetails, carrier?: string): Promise<{ trackingNumber: string; label: string }> {
73:     const selectedCarrier = carrier || selectCarrier(details.weight, details.value)
74:     const adapter = this.adapters.get(selectedCarrier)
75: 
76:     if (!adapter) {
